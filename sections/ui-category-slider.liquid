{% comment %} {{ 'css/components/ui-category-slider.css' | asset_url | stylesheet_tag }} {% endcomment %}

<section class="ui-category-slider">
  <div class="page-width">
    {% if section.settings.title != blank %}
      <div class="ui-category-slider__header">
        <h2>{{ section.settings.title }}</h2>
      </div>
    {% endif %}

    <slider-interface>
      <div class="ui-category-slider__wrapper">
        <ul
          class="ui-category-slider__list ui-category-slider--{{ section.settings.cards_per_row }}"
          slider-card-list
          data-cards-per-slide="{{ section.settings.cards_per_row }}"
        >
          {% for block in section.blocks %}
            <li class="ui-category-slider__item" slider-card>

              {% liquid
                assign category = block.settings.collection
                assign selected_product = block.settings.product
                assign preferred_source = block.settings.card_source | default: 'collection'
                assign product_tag_filter = block.settings.product_tag | default: 'featured-product'

                assign card_title = blank
                assign card_link = blank
                assign card_image = blank
                assign resolved_product = nil

                if preferred_source == 'product'
                  if selected_product
                    assign resolved_product = selected_product
                  elsif category
                    for product in category.products
                      if product.tags contains product_tag_filter
                        assign resolved_product = product
                        break
                      endif
                    endfor

                    if resolved_product == nil and category.products_count > 0
                      assign resolved_product = category.products | first
                    endif
                  endif
                endif

                if resolved_product
                  assign card_title = resolved_product.title
                  assign card_link = resolved_product.url
                  assign card_image = resolved_product.featured_image
                elsif category
                  assign card_title = category.title
                  assign card_link = category.url
                  assign card_image = category.image | default: category.products.first.featured_image
                elsif selected_product
                  assign card_title = selected_product.title
                  assign card_link = selected_product.url
                  assign card_image = selected_product.featured_image
                endif
              %}

              {% if card_link and card_title %}
                {% render 'ui-product-card',
 image: card_image,
 title: card_title,
 link: card_link
                %}
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </div>

      <div class="ui-category-slider__nav" slider-nav>
        {%- liquid
          render 'm-slider-scroll-indicator'
        -%}
        {%- liquid
          render 'm-slider-btn'
        -%}
      </div>
    </slider-interface>
  </div>
</section>

{% schema %}
{
  "name": "UI Category Slider",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop By Category"
    },
    {
      "type": "select",
      "id": "cards_per_row",
      "label": "Cards per row",
      "options": [
        {
          "value": "6",
          "label": "6 Cards"
        },
        {
          "value": "4",
          "label": "4 Cards"
        },
        {
          "value": "3",
          "label": "3 Cards"
        }
      ],
      "default": "6"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "select",
          "id": "card_source",
          "label": "Content source",
          "default": "collection",
          "options": [
            {
              "value": "collection",
              "label": "Use collection"
            },
            {
              "value": "product",
              "label": "Use featured product"
            }
          ]
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Select category"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Select featured product",
          "info": "Overrides the category card when set"
        },
        {
          "type": "text",
          "id": "product_tag",
          "label": "Auto-pick product tag",
          "default": "featured-product",
          "info": "Used when card source is product but no product is chosen"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UI Category Slider"
    }
  ]
}
{% endschema %}
